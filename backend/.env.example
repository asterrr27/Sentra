# Database
DATABASE_URL=sqlite:///./agent_auditor.db

# JWT secret (required — generate a strong random value for production)
# Run: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-not-for-production

# OpenAI (optional — leave blank to use mock agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rate limiting
RATE_LIMIT=10/minute

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Custom agent webhook timeout (seconds)
CUSTOM_AGENT_TIMEOUT=15
